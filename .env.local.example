
# Email (SMTP)
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe

# IA API Key (Mistral / OpenRouter / Ollama)
IA_API_KEY=

# Super-admin (page /super-admin/dashboard).
# Mot de passe seul = l'email autorisé est dans data/config/settings.json (superAdmin.email).
# Sans cette variable, l'auth super-admin est désactivée et les endpoints renvoient 503.
SUPER_ADMIN_PASSWORD=

# Webhook sortant (notifications tenant.created / tenant.deleted).
# URL du webhook. Si vide, le code retombe sur data/config/settings.json (webhook.url).
WEBHOOK_URL=https://api.pushover.net/1/messages.json

# Pushover (mode "pushover" du webhook). Prioritaires sur settings.json.
# Si l'une des deux est vide, le code retombe sur settings.json et loggue un warning.
# Générer / révoquer sur https://pushover.net/apps/build.php
PUSHOVER_TOKEN=
PUSHOVER_USER=


# Email (SMTP)
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe

# IA API Key (Mistral / OpenRouter / Ollama)
IA_API_KEY=

# Super-admin (page /super-admin/dashboard).
# Mot de passe seul = l'email autorisé est dans data/config/settings.json (superAdmin.email).
# Sans cette variable, l'auth super-admin est désactivée et les endpoints renvoient 503.
SUPER_ADMIN_PASSWORD=